# Buffalo runtime environment (development | test | production)
# Default: development
GO_ENV=development

# Secret used to sign session cookies (min 32 chars)
# REQUIRED in production!
SESSION_SECRET=changeme-use-a-random-secret-in-production

# PostgreSQL connection URLs
# Default values used in database.yml if not set
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/buffalo_test_development?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/buffalo_test_test?sslmode=disable

# HTTP server bind address
# Default: 127.0.0.1 (Use 0.0.0.0 for Docker)
ADDR=127.0.0.1

# HTTP server port
# Default: 3000
PORT=3000

# Force redirect to HTTPS
# Default: false
FORCE_SSL=false

# SMTP configuration for email delivery
# If not configured, emails will be logged to console instead of sent
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
